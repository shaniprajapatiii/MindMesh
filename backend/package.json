{
  "name": "mindmesh-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "node -e \"console.log('MongoDB uses seed-based setup instead of migrations')\"",
    "db:migrate:prod": "node -e \"console.log('MongoDB uses seed-based setup instead of migrations')\"",
    "db:seed": "tsx src/seed.ts",
    "db:generate": "node -e \"console.log('MongoDB does not require client generation')\"",
    "db:studio": "node -e \"console.log('Use MongoDB Compass or mongosh for MongoDB')\"",
    "db:reset": "tsx src/seed.ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.18.3",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "dotenv": "^16.4.5",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.13",
    "axios": "^1.6.8",
    "socket.io": "^4.7.5",
    "node-cron": "^3.0.3",
    "express-rate-limit": "^7.2.0",
    "multer": "^1.4.5-lts.1",
    "zod": "^3.22.4",
    "@anthropic-ai/sdk": "^0.21.1",
    "openai": "^4.33.0",
    "rss-parser": "^3.13.0",
    "google-auth-library": "^9.7.0",
    "mongoose": "^8.13.1",
    "uuid": "^9.0.1",
    "tsx": "^4.7.2",
    "typescript": "^5.4.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/uuid": "^9.0.8",
    "@types/node": "^20.12.0",
    "@types/nodemailer": "^6.4.14"
  }
}