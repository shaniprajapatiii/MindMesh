// This is your Prisma schema file
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(uuid())
  name            String
  email           String    @unique
  username        String    @unique
  password        String?
  avatar          String?
  bio             String?
  location        String?
  college         String?
  github          String?
  twitter         String?
  linkedin        String?
  isPublic        Boolean   @default(true)
  isEmailVerified Boolean   @default(false)
  role            String    @default("user")
  
  // Platform IDs
  leetcodeId      String?
  codeforcesId    String?
  codechefId      String?
  gfgId           String?
  githubId        String?
  atcoderId       String?
  
  // Platform stats (cached)
  leetcodeSolved  Int       @default(0)
  leetcodeEasy    Int       @default(0)
  leetcodeMedium  Int       @default(0)
  leetcodeHard    Int       @default(0)
  cfRating        Int       @default(0)
  cfMaxRating     Int       @default(0)
  cfRank          String?
  codechefRating  Int       @default(0)
  codechefStars   Int       @default(0)
  gfgScore        Int       @default(0)
  gfgSolved       Int       @default(0)
  
  // Gamification
  xp              Int       @default(0)
  level           Int       @default(1)
  streak          Int       @default(0)
  maxStreak       Int       @default(0)
  lastActiveDate  DateTime?
  
  // Settings
  editorTheme     String    @default("vs-dark")
  defaultLanguage String    @default("javascript")
  fontSize        Int       @default(14)
  notifDaily      Boolean   @default(true)
  notifStreak     Boolean   @default(true)
  notifRevision   Boolean   @default(true)
  notifContest    Boolean   @default(true)
  notifEmail      Boolean   @default(false)
  showOnLeader    Boolean   @default(true)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  notes           Note[]
  submissions     Submission[]
  sheetProgress   SheetProgress[]
  problemStatus   UserProblemStatus[]
  badges          UserBadge[]
  posts           CommunityPost[]
  postLikes       PostLike[]
  groupMembers    GroupMember[]
  activityLogs    ActivityLog[]
  otpCodes        OtpCode[]
  bookmarks       ProblemBookmark[]
  revisionQueue   RevisionQueue[]
  
  @@map("users")
}

model OtpCode {
  id        String   @id @default(uuid())
  userId    String?
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  
  @@map("otp_codes")
}

model Problem {
  id          String   @id @default(uuid())
  externalId  String?
  title       String
  slug        String?
  number      Int?
  platform    String   // leetcode, codeforces, codechef, gfg
  url         String
  difficulty  String   // Easy, Medium, Hard
  topic       String?
  tags        String[] @default([])
  description String?
  examples    Json?
  constraints String?
  acceptance  Float?
  frequency   Float?
  isPremium   Boolean  @default(false)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  userStatus     UserProblemStatus[]
  submissions    Submission[]
  sheetItems     SheetItem[]
  bookmarks      ProblemBookmark[]
  revisionQueue  RevisionQueue[]
  noteTags       NoteTag[]
  
  @@unique([platform, externalId])
  @@map("problems")
}

model UserProblemStatus {
  id          String   @id @default(uuid())
  userId      String
  problemId   String
  status      String   @default("unsolved") // solved, attempted, unsolved
  solvedAt    DateTime?
  attempts    Int      @default(0)
  timeTaken   Int?     // seconds
  notes       String?
  rating      Int?     // 1-5 difficulty rating by user
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem     Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  
  @@unique([userId, problemId])
  @@map("user_problem_status")
}

model ProblemBookmark {
  id        String  @id @default(uuid())
  userId    String
  problemId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  
  @@unique([userId, problemId])
  @@map("problem_bookmarks")
}

model Submission {
  id          String   @id @default(uuid())
  userId      String
  problemId   String
  language    String
  code        String
  status      String   // accepted, wrong_answer, tle, mle, runtime_error
  runtime     Int?     // ms
  memory      Float?   // MB
  testsPassed Int?
  testsTotal  Int?
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem     Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  
  @@map("submissions")
}

model Note {
  id           String   @id @default(uuid())
  userId       String
  title        String
  content      String
  mode         String   @default("simple") // simple, markdown
  pinned       Boolean  @default(false)
  problemId    String?
  problemTitle String?
  
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tags         NoteTag[]
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  @@map("notes")
}

model NoteTag {
  id        String   @id @default(uuid())
  noteId    String
  problemId String?
  tag       String
  
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  problem   Problem? @relation(fields: [problemId], references: [id])
  
  @@map("note_tags")
}

model DSASheet {
  id          String   @id @default(uuid())
  name        String
  author      String
  description String?
  level       String?
  url         String?
  isPublic    Boolean  @default(true)
  createdBy   String?
  emoji       String?
  
  items       SheetItem[]
  progress    SheetProgress[]
  
  createdAt   DateTime @default(now())
  
  @@map("dsa_sheets")
}

model SheetItem {
  id        String  @id @default(uuid())
  sheetId   String
  problemId String
  order     Int
  topic     String?
  
  sheet     DSASheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  problem   Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  
  @@unique([sheetId, problemId])
  @@map("sheet_items")
}

model SheetProgress {
  id        String  @id @default(uuid())
  userId    String
  sheetId   String
  problemId String
  solved    Boolean @default(false)
  solvedAt  DateTime?
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sheet     DSASheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  
  @@unique([userId, sheetId, problemId])
  @@map("sheet_progress")
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String
  date      DateTime @default(now())
  dateStr   String   // YYYY-MM-DD
  count     Int      @default(1)
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, dateStr])
  @@map("activity_logs")
}

model RevisionQueue {
  id         String   @id @default(uuid())
  userId     String
  problemId  String
  nextReview DateTime
  interval   Int      @default(1) // days
  easeFactor Float    @default(2.5)
  repetitions Int     @default(0)
  
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem    Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  
  @@unique([userId, problemId])
  @@map("revision_queue")
}

model UserBadge {
  id        String   @id @default(uuid())
  userId    String
  badgeId   String
  earnedAt  DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, badgeId])
  @@map("user_badges")
}

model CommunityPost {
  id         String   @id @default(uuid())
  userId     String
  title      String
  content    String
  category   String
  tags       String[] @default([])
  pinned     Boolean  @default(false)
  views      Int      @default(0)
  
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes      PostLike[]
  replies    PostReply[]
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  @@map("community_posts")
}

model PostLike {
  id     String @id @default(uuid())
  postId String
  userId String
  
  post   CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([postId, userId])
  @@map("post_likes")
}

model PostReply {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  content   String
  
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  
  @@map("post_replies")
}

model StudyGroup {
  id          String   @id @default(uuid())
  name        String
  description String?
  emoji       String?
  isPublic    Boolean  @default(true)
  createdBy   String
  
  members     GroupMember[]
  
  createdAt   DateTime @default(now())
  
  @@map("study_groups")
}

model GroupMember {
  id      String @id @default(uuid())
  groupId String
  userId  String
  role    String @default("member") // admin, member
  
  group   StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([groupId, userId])
  @@map("group_members")
}
